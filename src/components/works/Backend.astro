---
import H from "../utils/H";

const achievements = [
  {
    id: "data-science",
    category: "Big Data",
    title: "PPS-Calibview at CERN",
    description:
      "I developed a data processing app for visualizing and analyzing data from the PPS2 detector (part of the CMS experiment)",
    tags: ["📊 Petabyte scale", "⚡ Data processing optimization"],
    hoverColor: "",
    delay: "200",
  },
  {
    id: "leadership",
    category: "Leadership",
    title: "Poznaj Góry Student Project",
    description:
      "As the co-founder, I lead a diverse team of 15 people to build a comprehensive mountain exploration platform.",
    tags: ["🎯 Full-stack leadership", "🛠️ Infrastructure design"],
    hoverColor: "",
    delay: "300",
  },
  {
    id: "personal",
    category: "Largest personal project",
    title: "Hotel Reservation System",
    description:
      "I've built a complete hotel management solution from scratch. Real-time booking, payments, inventory management, and analytics - everything a modern hotel needs.",
    tags: ["💳 Payment processing", "📈 Analytics dashboard"],
    hoverColor: "",
    delay: "400",
  },
  {
    id: "enterprise",
    category: "Enterprise work",
    title: "DHCP Server at AVSystem",
    description:
      "During my summer internship, I contributed to the development of a DHCP server, focusing on improving its usability and scalability.",
    tags: ["🌐 Global deployment", "⚡ Full-stack development"],
    hoverColor: "",
    delay: "100",
  },
];
---

<!-- Page Header -->
<H text="Backend + System Design" />

<!-- Introduction -->
<p data-aos="fade-up" class="paragraph">
  I'm passionate about building systems that actually work at scale! Below are some highlights of my backend-related
  experience:
</p>

<!-- Achievements Section -->

<ul class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-6xl mx-auto mt-8 px-4">
  {
    achievements.map(achievement => (
      <li
        data-aos="fade-up"
        data-aos-delay={achievement.delay}
        class={`achievement-card bg-white p-8 rounded-xl border-2 border-primary-200 ${achievement.hoverColor}`}
      >
        <header>
          <p class="achievement-category text-3xl" aria-label={`Category: ${achievement.category}`}>
            {achievement.category}
          </p>
          <h3 id={`achievement-${achievement.id}-title`} class="achievement-title font-primary font-bold my-3">
            {achievement.title}
          </h3>
        </header>
        <p class="achievement-description text-primary-700 leading-relaxed mb-4">{achievement.description}</p>
        <footer>
          <ul class="tag-container" aria-label="Technologies and highlights">
            {achievement.tags.map(tag => (
              <li class="tag tag-primary">{tag}</li>
            ))}
          </ul>
        </footer>
      </li>
    ))
  }
</ul>

<style>
  @import "~/global.css" reference;

  /* Achievement Cards with Enhanced Hover Transitions */
  .achievement-card {
    @apply relative overflow-hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }

  /* Category Title Animation */
  .achievement-category {
    @apply transition-all duration-300 ease-in-out;
  }

  /* Title Animation */
  .achievement-title {
    @apply relative transition-all duration-300 ease-out;
  }

  /* Description Animation */
  .achievement-description {
    @apply transition-all duration-300 ease-in-out;
  }
</style>
